# Copy this to .env.local for local dev.
# In Vercel: Project → Settings → Environment Variables.

# Your Google Sheet CSV export URL (see README for how to get this)
VITE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Admin page password
VITE_ADMIN_PASSWORD=choose-something-secret

# Challenge window (ISO 8601 — adjust timezone offset as needed)
VITE_CHALLENGE_START=2025-04-20T00:00:00+09:00
VITE_CHALLENGE_END=2025-05-11T23:59:59+09:00
